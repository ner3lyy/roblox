    end
end)

-- Банихоп + спин

local isBhopActive = false
local SPEED = 70
local JUMP_COOLDOWN = 0.4
local SPIN_SPEED = 30 -- градусов в кадр

local lastJumpTime = 0
local currentYRotation = 0

local bhopConnection = nil

local function startBhop()
    humanoid.AutoRotate = false
    humanoid.WalkSpeed = SPEED
    lastJumpTime = 0
    currentYRotation = 0

    bhopConnection = RunService.RenderStepped:Connect(function(dt)
        local moveDir = humanoid.MoveDirection
        if moveDir.Magnitude > 0 then
            if tick() - lastJumpTime > JUMP_COOLDOWN and humanoid.FloorMaterial ~= Enum.Material.Air then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                lastJumpTime = tick()
            end
        end
        currentYRotation = currentYRotation + math.rad(SPIN_SPEED)
        local lookDirection = moveDir.Magnitude > 0 and moveDir or rootPart.CFrame.LookVector
        local lookCFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + lookDirection)
        local spinRotation = CFrame.Angles(0, currentYRotation, 0)
        rootPart.CFrame = lookCFrame * spinRotation
    end)
end

local function stopBhop()
    if bhopConnection then
        bhopConnection:Disconnect()
        bhopConnection = nil
    end
    humanoid.AutoRotate = true
    humanoid.WalkSpeed = 16 -- стандартная скорость
end

btnBhop.MouseButton1Click:Connect(function()
    isBhopActive = not isBhopActive
    if isBhopActive then
        startBhop()
        btnBhop.Text = "Банихоп Вкл"
    else
        stopBhop()
        btnBhop.Text = "Банихоп + спин"
    end
end)

-- Антирагдолл

local isAntiRagdollActive = false

local function fixRagdoll()
    for _, part in pairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, obj in pairs(part:GetChildren()) do
                if obj:IsA("BodyVelocity") or obj:IsA("BodyAngularVelocity") or obj:IsA("BodyForce") or obj:IsA("BodyPosition") then
                    obj:Destroy()
                end
            end
        end
    end
end

local function onStateChanged(oldState, newState)
    if isAntiRagdollActive then
        if newState == Enum.HumanoidStateType.Ragdoll or newState == Enum.HumanoidStateType.FallingDown then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            fixRagdoll()
        end
    end
end

local stateChangedConnection = nil
local fixRagdollLoop = nil

btnAntiRagdoll.MouseButton1Click:Connect(function()
    isAntiRagdollActive = not isAntiRagdollActive
    if isAntiRagdollActive then
        btnAntiRagdoll.Text = "Антирагдолл Вкл"
        if not stateChangedConnection then
            stateChangedConnection = humanoid.StateChanged:Connect(onStateChanged)
        end
        if not fixRagdollLoop then
            fixRagdollLoop = coroutine.create(function()
                while isAntiRagdollActive do
                    fixRagdoll()
                    wait(0.1)
                end
            end)
            coroutine.resume(fixRagdollLoop)
        end
    else
        btnAntiRagdoll.Text = "Антирагдолл"
        if stateChangedConnection then
            stateChangedConnection:Disconnect()
            stateChangedConnection = nil
        end
        fixRagdollLoop = nil
    end
end)

-- ESP (Highlight вокруг HumanoidRootPart, видимый через стены)

local isESPActive = false
local espHighlights = {}

-- Функция включения ESP
local function enableESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            if not espHighlights[p] then
                local highlight = Instance.new("Highlight")
                highlight.Adornee = p.Character
                highlight.FillColor = Color3.new(1, 0, 0)
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.new(1, 0, 0)
                highlight.OutlineTransparency = 0
                highlight.Parent = p.Character
                espHighlights[p] = highlight
            end
        end
    end
end

-- Функция выключения ESP
local function disableESP()
    for _, highlight in pairs(espHighlights) do
        if highlight then
            highlight:Destroy()
        end
    end
    espHighlights = {}
end

-- Добавляем подсветку новому персонажу игрока
local function setupHighlightForPlayer(p)
    p.CharacterAdded:Connect(function(char)
        if isESPActive then
            -- Удаляем старый highlight, если есть
            if espHighlights[p] then
                espHighlights[p]:Destroy()
                espHighlights[p] = nil
            end
            -- Создаем новый
            local highlight = Instance.new("Highlight")
            highlight.Adornee = char
            highlight.FillColor = Color3.new(1, 0, 0)
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.new(1, 0, 0)
            highlight.OutlineTransparency = 0
            highlight.Parent = char
            espHighlights[p] = highlight
        end
    end)
    -- Если персонаж уже есть (редкий случай)
    if isESPActive and p.Character then
        if espHighlights[p] then
            espHighlights[p]:Destroy()
            espHighlights[p] = nil
        end
        local highlight = Instance.new("Highlight")
        highlight.Adornee = p.Character
        highlight.FillColor = Color3.new(1, 0, 0)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.new(1, 0, 0)
        highlight.OutlineTransparency = 0
        highlight.Parent = p.Character
        espHighlights[p] = highlight
    end
end

-- Отслеживаем новых игроков, чтобы добавить им Highlight
Players.PlayerAdded:Connect(function(p)
    if p ~= player then
        setupHighlightForPlayer(p)
    end
end)

-- Отслеживаем уход игроков, чтобы удалить их Highlight
Players.PlayerRemoving:Connect(function(p)
    if espHighlights[p] then
        espHighlights[p]:Destroy()
        espHighlights[p] = nil
    end
end)

-- Следим за сменой персонажа локального игрока и отключаем ESP при смерти
local function onCharacterAdded(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        if isESPActive then
            isESPActive = false
            btnESP.Text = "ESP"
            disableESP()
        end
    end)
end

if player.Character then
    onCharacterAdded(player.Character)
end

player.CharacterAdded:Connect(onCharacterAdded)

-- Подключаем уже существующих игроков (для локального игрока)
for _, p in pairs(Players:GetPlayers()) do
    if p ~= player then
        setupHighlightForPlayer(p)
    end
end

