-- Обновление позиции GUI над головой
local function updatePosition()
    if head and head.Parent then
        local headPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
        if onScreen then
            frame.Position = UDim2.new(0, headPos.X - frame.Size.X.Offset/2, 0, headPos.Y)
            frame.Visible = frame.Visible
        else
            frame.Visible = false
        end
    else
        frame.Visible = false
    end
end

-- Показ/скрытие GUI по клавише R и включение банихопа по F
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R then
        frame.Visible = not frame.Visible
    elseif input.KeyCode == Enum.KeyCode.F then
        -- Переключаем банихоп
        isBhopActive = not isBhopActive
        if isBhopActive then
            startBhop()
            btnBhop.Text = "Банихоп Вкл"
        else
            stopBhop()
            btnBhop.Text = "Банихоп + спин"
        end
    end
end)

RunService.RenderStepped:Connect(function()
